# --- Public Firebase config (bundled into client) ---
# From Firebase Console -> Project Settings -> General -> Your apps -> Web app config
NUXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAIMpVqRsX_DKfSg9fiDJYOv8Es6cbZ_KU
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xploit-games.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=xploit-games
NUXT_PUBLIC_FIREBASE_APP_ID=1:135390433914:web:4096592360e793784ce1c3

# Admin email for client-side UI gating (must match NUXT_SHORTIFY_ADMIN_EMAIL).
# Server-side auth still verifies via the private var; this one is just for hiding admin links.
NUXT_PUBLIC_ADMIN_EMAIL=xploit.ravy@gmail.com

# --- Server-only ---
# Email allowed to access /shortify and /api/shortify/*
NUXT_SHORTIFY_ADMIN_EMAIL=xploit.ravy@gmail.com

# OpenAI API key used by private contract scanner endpoint.
NUXT_OPENAI_API_KEY=sk-...

# Local dev only: path to a Firebase service-account JSON.
# In Firebase App Hosting this is provided automatically (Application Default Credentials).
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

NUXT_OG_IMAGE_SECRET=ed497...

# --- Steam AI Disclosure service ---
# Stripe (use test keys for local dev). Secret key + the one-time Price ID.
NUXT_STRIPE_SECRET_KEY=sk_test_...
NUXT_STRIPE_PRICE_ID=price_...
# Webhook signing secret. Local dev: run `stripe listen --forward-to localhost:3000/api/steam-audit/webhook`
# and copy the printed `whsec_...` here.
NUXT_STRIPE_WEBHOOK_SECRET=whsec_...
# Secret used to sign result-access links (any long random string).
NUXT_STEAM_AUDIT_TOKEN_SECRET=change-me-to-a-long-random-string
# Resend API key for emailing the result link (optional; result page works without it).
NUXT_RESEND_API_KEY=re_...
# Newsletter: with the API key alone, subscribers land in Resend global Contacts.
# Optionally set a Segment id (Resend dashboard → Contacts → Segments) to also
# group subscribers into a segment you can target with broadcasts.
NUXT_RESEND_SEGMENT_ID=
# Public display price (USD, no symbol). Must match the amount on the Stripe Price above.
NUXT_PUBLIC_STEAM_AUDIT_PRICE_USD=39
